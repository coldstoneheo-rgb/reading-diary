# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# NAVER_CLIENT_ID: Option client ID for Naver Book Search API integration
NAVER_CLIENT_ID=NAVER_CLIENT_ID_PLACEHOLDER
# NAVER_CLIENT_SECRET: Option client secret for Naver Book Search API integration
NAVER_CLIENT_SECRET=NAVER_CLIENT_SECRET_PLACEHOLDER
